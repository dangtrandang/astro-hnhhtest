---
// Hero.astro - Celestial Editorial Redesign matching mockup 100%
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-brand-light pt-36 pb-28 px-6">
  <!-- Soft glowing ambient circular aura behind the portal -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-muted/15 rounded-full filter blur-[130px] pointer-events-none z-0"></div>

  <!-- Main Column Layout - Centered Flow -->
  <div class="relative z-20 w-full max-w-4xl mx-auto flex flex-col items-center text-center">
    
    <!-- 1. The Gorgeous Portrait Archway Portal on top -->
    <div class="relative mb-14 animate-fade-in">
      <!-- Rotating/Diagonal Celestial Orbit Line -->
      <div class="absolute inset-[-24px] border border-[#C5A880]/30 rounded-full rotate-[-12deg] pointer-events-none z-0"></div>
      <div class="absolute inset-[-12px] border border-[#C5A880]/15 rounded-full rotate-[35deg] pointer-events-none z-0"></div>

      <!-- The Celestial Archway -->
      <div class="w-[230px] h-[320px] sm:w-[270px] sm:h-[370px] rounded-t-[12rem] rounded-b-[2rem] overflow-hidden border border-[#C5A880]/40 p-2.5 bg-white/30 backdrop-blur-sm shadow-[0_20px_50px_rgba(43,30,30,0.03)] z-10 relative">
        <div class="w-full h-full rounded-t-[11rem] rounded-b-[1.5rem] overflow-hidden relative">
          <img 
            src="/mystical_hero_art.png" 
            alt="Hồng Ngọc Chân Dung Sáng Lập" 
            class="w-full h-full object-cover transition-transform duration-[2000ms] hover:scale-105"
          />
          <!-- Gentle warm golden gradient overlay inside -->
          <div class="absolute inset-0 bg-gradient-to-tr from-brand-primary/5 via-transparent to-white/10 mix-blend-overlay pointer-events-none"></div>
        </div>
      </div>

      <!-- Sparkle 1: Top-Left (4-point star) -->
      <div class="absolute -top-6 -left-6 z-20 pointer-events-none opacity-60 text-[#C5A880] animate-pulse">
        <svg viewBox="0 0 100 100" class="w-7 h-7">
          <polygon points="50,15 58,42 85,50 58,58 50,85 42,58 15,50 42,42" fill="currentColor" />
        </svg>
      </div>

      <!-- Sparkle 2: Bottom-Right (4-point star) -->
      <div class="absolute -bottom-4 -right-6 z-20 pointer-events-none opacity-40 text-[#C5A880] animate-pulse-delay">
        <svg viewBox="0 0 100 100" class="w-5 h-5">
          <polygon points="50,15 58,42 85,50 58,58 50,85 42,58 15,50 42,42" fill="currentColor" />
        </svg>
      </div>
    </div>

    <!-- 2. Slogan & Slogan Headline Underneath -->
    <div class="flex flex-col items-center max-w-2xl animate-fade-in-up">
      <span class="text-brand-primary uppercase tracking-[0.25em] text-[10px] md:text-xs font-bold mb-5 block">
        ✦ Trạm dừng chân bình yên cho tâm hồn
      </span>

      <!-- Title Headline -->
      <h1 class="font-serif text-4xl md:text-5xl lg:text-[4rem] text-brand-dark leading-[1.2] mb-6 font-light">
        <span class="block font-serif font-bold text-brand-primary tracking-wide italic">
          Hồng Ngọc
        </span>
        <span class="block font-serif text-brand-dark uppercase tracking-[0.2em] text-3xl md:text-4xl lg:text-5xl mt-2 font-semibold border-b border-brand-primary/10 pb-6 w-full max-w-md mx-auto">
          Huyền Học
        </span>
      </h1>

      <!-- Quote under the title -->
      <p class="font-serif text-xl md:text-2xl italic text-brand-dark/95 mt-4 mb-6 leading-normal font-light">
        "Thay đổi góc nhìn để thay đổi vấn đề."
      </p>

      <!-- Description paragraph -->
      <p class="text-brand-dark/75 text-sm md:text-base lg:text-lg max-w-xl mb-10 leading-relaxed font-light">
        Khi bạn sẵn sàng soi chiếu lại câu chuyện dưới một lăng kính thấu suốt và trung lập, mọi bế tắc đều tự khắc tìm thấy lối ra.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center gap-6 w-full justify-center">
        <a 
          href="#booking"
          class="inline-flex items-center justify-center bg-brand-primary text-brand-light px-8 py-4 rounded-full text-xs tracking-widest uppercase font-bold hover:bg-[#6c0b2b] transition-all duration-300 shadow-[0_8px_25px_rgba(133,14,53,0.1)] hover:-translate-y-0.5 hover:shadow-[0_12px_35px_rgba(133,14,53,0.2)] cursor-pointer text-center min-w-[200px]"
        >
          Trò chuyện cùng Ngọc
        </a>
        <a 
          href="#about"
          class="inline-flex items-center justify-center text-brand-dark/75 hover:text-brand-primary transition-all duration-300 font-serif italic text-sm underline underline-offset-8 decoration-brand-primary/30 hover:decoration-brand-primary"
        >
          Tìm hiểu về Hồng Ngọc →
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  /* Custom micro-animations for high-end static loading experience */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(25px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 1.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .animate-fade-in-up {
    animation: fadeInUp 1.8s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
    opacity: 0;
  }
  .animate-pulse-delay {
    animation: pulse 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    animation-delay: 1.2s;
  }
</style>
